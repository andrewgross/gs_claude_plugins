{
  "name": "terminal-notifier",
  "description": "Native macOS notifications when Claude finishes responding",
  "version": "1.0.0",
  "hooks": {
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/task_completion_hook.py"
          }
        ]
      }
    ]
  }
}
